{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/bff-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "Authentication": {
    "Cookie": {
      "Name": ".Ladral.ToDo.Auth"
    },
    "OpenIdConnect": {
      "Scopes": [
        "openid",
        "profile",
        "read:todo",
        "write:todo"
      ]
    }
  },
  "ReverseProxy": {
    "Routes": {
      "api-route": {
        "ClusterId": "ApiCluster",
        "Match": {
          "Path": "/api/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api" },
          { "RequestHeaderOriginalHost": "true" }
        ]
      }
    },
    "Clusters": {
      "ApiCluster": {
        "Destinations": {
          "ApiDestination": {
            "Address": "https://localhost:7173"
          }
        }
      }
    }
  }
}